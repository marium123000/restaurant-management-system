@model OnlineRest.Models.SalesReportVM
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard
        </h2>
        <div>
            <span class="text-muted">Welcome, Admin</span>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-2 opacity-75">Total Revenue</p>
                            <h2 class="fw-bold mb-0">$@Model.TotalRevenue.ToString("F2")</h2>
                        </div>
                        <i class="fas fa-dollar-sign fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-2 opacity-75">Total Orders</p>
                            <h2 class="fw-bold mb-0">@Model.TotalOrders</h2>
                        </div>
                        <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-2 opacity-75">Total Customers</p>
                            <h2 class="fw-bold mb-0">@Model.TotalCustomers</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-2 opacity-75">Pending Orders</p>
                            <h2 class="fw-bold mb-0">@Model.PendingOrders</h2>
                        </div>
                        <i class="fas fa-clock fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Recent Orders -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-list me-2"></i>Recent Orders
                    </h5>
                    <a asp-action="Orders" class="btn btn-sm btn-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="p-3">Order #</th>
                                    <th class="p-3">Customer</th>
                                    <th class="p-3">Date</th>
                                    <th class="p-3 text-end">Amount</th>
                                    <th class="p-3 text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders.Take(10))
                                {
                                    var statusClass = order.Status switch
                                    {
                                        "Delivered" => "status-delivered",
                                        "Out for Delivery" => "status-out-for-delivery",
                                        "Processing" => "status-processing",
                                        "Cancelled" => "status-cancelled",
                                        _ => "status-pending"
                                    };

                                    <tr>
                                        <td class="p-3 fw-bold">#@order.Id</td>
                                        <td class="p-3">@order.User?.Name</td>
                                        <td class="p-3">@order.OrderDate.ToString("MMM dd, hh:mm tt")</td>
                                        <td class="p-3 text-end fw-bold">$@order.TotalAmount.ToString("F2")</td>
                                        <td class="p-3 text-center">
                                            <span class="status-badge @statusClass">@order.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Selling Items & Pending Reservations -->
        <div class="col-lg-4">
            <!-- Top Selling Items -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-fire me-2 text-danger"></i>Top Selling Items
                    </h5>
                </div>
                <div class="card-body p-4">
                    @foreach (var item in Model.PopularItems.Take(5))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h6 class="mb-1 fw-bold">@item.FoodItemName</h6>
                                <small class="text-muted">@item.TotalQuantity sold</small>
                            </div>
                            <span class="badge bg-primary">$@item.Revenue.ToString("F0")</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Pending Reservations -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-calendar-check me-2"></i>Pending Reservations
                    </h5>
                    <span class="badge bg-warning">@Model.PendingReservations.Count</span>
                </div>
                <div class="card-body p-4">
                    @if (Model.PendingReservations.Any())
                    {
                        foreach (var reservation in Model.PendingReservations)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <h6 class="fw-bold mb-1">@reservation.CustomerName</h6>
                                <p class="small text-muted mb-1">
                                    <i class="fas fa-calendar me-1"></i>@reservation.ReservationDate.ToString("MMM dd, yyyy")
                                    <i class="fas fa-clock ms-2 me-1"></i>@reservation.ReservationTime
                                </p>
                                <p class="small text-muted mb-0">
                                    <i class="fas fa-users me-1"></i>@reservation.NumberOfGuests guests
                                </p>
                            </div>
                        }
                        <a asp-action="Reservations" class="btn btn-sm btn-outline-primary w-100">
                            View All Reservations
                        </a>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">No pending reservations</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-md-3 mb-3">
            <a asp-action="Orders" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-shopping-cart fa-3x mb-3" style="color: var(--primary-color);"></i>
                    <h6 class="fw-bold">Manage Orders</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a asp-action="FoodItems" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-utensils fa-3x mb-3" style="color: var(--primary-color);"></i>
                    <h6 class="fw-bold">Manage Menu</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a asp-action="Reservations" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-calendar-alt fa-3x mb-3" style="color: var(--primary-color);"></i>
                    <h6 class="fw-bold">Reservations</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a asp-action="SalesReport" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-chart-line fa-3x mb-3" style="color: var(--primary-color);"></i>
                    <h6 class="fw-bold">Sales Report</h6>
                </div>
            </a>
        </div>
    </div>
</div>
