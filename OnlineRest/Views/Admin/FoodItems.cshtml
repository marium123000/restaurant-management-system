@model IEnumerable<OnlineRest.Models.FoodItem>

@{
    ViewData["Title"] = "Food Items";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fas fa-utensils me-2"></i>Food Items
        </h2>
        <a asp-action="CreateFoodItem" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Item
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="p-3">Image</th>
                            <th class="p-3">Name</th>
                            <th class="p-3">Category</th>
                            <th class="p-3">Description</th>
                            <th class="p-3 text-end">Price</th>
                            <th class="p-3 text-center">Available</th>
                            <th class="p-3 text-center">Sold</th>
                            <th class="p-3 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="p-3">
                                    <img src="@item.ImageUrl" alt="@item.Name" 
                                         style="width: 60px; height: 60px; object-fit: cover; border-radius: 0.5rem;" />
                                </td>
                                <td class="p-3">
                                    <strong>@item.Name</strong>
                                </td>
                                <td class="p-3">
                                    <span class="badge bg-secondary">@item.Category</span>
                                </td>
                                <td class="p-3">
                                    <small class="text-muted">@item.Description</small>
                                </td>
                                <td class="p-3 text-end fw-bold">$@item.Price.ToString("F2")</td>
                                <td class="p-3 text-center">
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of Stock</span>
                                    }
                                </td>
                                <td class="p-3 text-center">
                                    <span class="badge bg-info">@item.TotalSold</span>
                                </td>
                                <td class="p-3 text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditFoodItem" asp-route-id="@item.Id" 
                                           class="btn btn-outline-primary">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="DeleteFoodItem" asp-route-id="@item.Id" 
                                           class="btn btn-outline-danger"
                                           onclick="return confirm('Delete this item?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>