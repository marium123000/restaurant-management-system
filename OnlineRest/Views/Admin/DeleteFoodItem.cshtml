@model OnlineRest.Models.FoodItem

@{
    ViewData["Title"] = "Delete Food Item";
}

<div class="container-fluid my-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0 text-danger">
                    <i class="fas fa-trash-alt me-2"></i>Delete Food Item
                </h2>
                <a asp-action="FoodItems" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white p-3">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Warning:</strong> Are you sure you want to delete this food item? This action cannot be undone.
                    </div>

                    <!-- Item Preview -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-4 text-center mb-3 mb-md-0">
                                    <img src="@(Model.ImageUrl ?? "/images/placeholder.jpg")" 
                                         alt="@Model.Name" 
                                         class="img-fluid rounded"
                                         style="max-height: 150px; object-fit: cover;" />
                                </div>
                                <div class="col-md-8">
                                    <h4 class="fw-bold mb-3">@Model.Name</h4>
                                    
                                    <dl class="row mb-0">
                                        <dt class="col-sm-4">Category:</dt>
                                        <dd class="col-sm-8">
                                            <span class="badge bg-secondary">@Model.Category</span>
                                        </dd>

                                        <dt class="col-sm-4">Description:</dt>
                                        <dd class="col-sm-8">@Model.Description</dd>

                                        <dt class="col-sm-4">Price:</dt>
                                        <dd class="col-sm-8 fw-bold text-primary">$@Model.Price.ToString("F2")</dd>

                                        <dt class="col-sm-4">Status:</dt>
                                        <dd class="col-sm-8">
                                            @if (Model.IsAvailable)
                                            {
                                                <span class="badge bg-success">Available</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Unavailable</span>
                                            }
                                        </dd>

                                        <dt class="col-sm-4">Total Sold:</dt>
                                        <dd class="col-sm-8">
                                            <span class="badge bg-info">@Model.TotalSold units</span>
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="DeleteFoodItem" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="FoodItems" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-trash-alt me-2"></i>Delete Permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>