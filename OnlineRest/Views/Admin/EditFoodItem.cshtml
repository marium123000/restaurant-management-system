@model OnlineRest.Models.FoodItem

@{
    ViewData["Title"] = "Edit Food Item";
}

<div class="container-fluid my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">
                    <i class="fas fa-edit me-2"></i>Edit Food Item
                </h2>
                <a asp-action="FoodItems" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="EditFoodItem" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="TotalSold" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold">
                                    <i class="fas fa-utensils me-2"></i>Item Name *
                                </label>
                                <input asp-for="Name" class="form-control" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Category" class="form-label fw-bold">
                                    <i class="fas fa-tag me-2"></i>Category *
                                </label>
                                <select asp-for="Category" class="form-select" required>
                                    <option value="">Select Category</option>
                                    <option value="Appetizers">Appetizers</option>
                                    <option value="Main Course">Main Course</option>
                                    <option value="Desserts">Desserts</option>
                                    <option value="Beverages">Beverages</option>
                                </select>
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">
                                <i class="fas fa-align-left me-2"></i>Description *
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">
                                    <i class="fas fa-dollar-sign me-2"></i>Price *
                                </label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" required />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ImageUrl" class="form-label fw-bold">
                                    <i class="fas fa-image me-2"></i>Image URL
                                </label>
                                <input asp-for="ImageUrl" class="form-control" placeholder="/images/food-name.jpg" />
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                <small class="text-muted">Leave empty for placeholder image</small>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" 
                                       role="switch" id="availableSwitch" />
                                <label class="form-check-label fw-bold" for="availableSwitch">
                                    <i class="fas fa-check-circle me-2"></i>Available for Order
                                </label>
                            </div>
                        </div>

                        <!-- Stats Display -->
                        <div class="alert alert-info">
                            <i class="fas fa-chart-line me-2"></i>
                            <strong>Total Sold:</strong> @Model.TotalSold units
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                            <a asp-action="FoodItems" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}