@model List<OnlineRest.Models.Order>
@{
    ViewData["Title"] = "Order History";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4">
        <i class="fas fa-history me-2"></i>Order History
    </h2>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var order in Model)
            {
                var statusClass = order.Status switch
                {
                    "Delivered" => "status-delivered",
                    "Out for Delivery" => "status-out-for-delivery",
                    "Processing" => "status-processing",
                    "Cancelled" => "status-cancelled",
                    _ => "status-pending"
                };

                <div class="col-12 mb-4">
                    <div class="card shadow-sm border-0 fade-in">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <!-- Order Info -->
                                <div class="col-md-3 mb-3 mb-md-0">
                                    <h5 class="fw-bold mb-2">Order #@order.Id</h5>
                                    <p class="text-muted small mb-1">
                                        <i class="fas fa-calendar me-2"></i>@order.OrderDate.ToString("MMM dd, yyyy")
                                    </p>
                                    <p class="text-muted small mb-0">
                                        <i class="fas fa-clock me-2"></i>@order.OrderDate.ToString("hh:mm tt")
                                    </p>
                                </div>

                                <!-- Items Count -->
                                <div class="col-md-2 mb-3 mb-md-0 text-center">
                                    <i class="fas fa-shopping-bag fa-2x mb-2" style="color: var(--primary-color);"></i>
                                    <p class="mb-0 fw-bold">@(order.OrderDetails?.Count ?? 0) Items</p>
                                </div>

                                <!-- Total Amount -->
                                <div class="col-md-2 mb-3 mb-md-0 text-center">
                                    <p class="text-muted small mb-1">Total Amount</p>
                                    <h4 class="fw-bold mb-0" style="color: var(--primary-color);">
                                        $@order.TotalAmount.ToString("F2")
                                    </h4>
                                </div>

                                <!-- Status -->
                                <div class="col-md-2 mb-3 mb-md-0 text-center">
                                    <p class="text-muted small mb-2">Status</p>
                                    <span class="status-badge @statusClass">@order.Status</span>
                                </div>

                                <!-- Actions -->
                                <div class="col-md-3 text-center text-md-end">
                                    <a asp-action="OrderDetails" asp-route-id="@order.Id" 
                                       class="btn btn-primary btn-sm mb-2 w-100">
                                        <i class="fas fa-eye me-1"></i>View Details
                                    </a>
                                    <a asp-action="DownloadReceipt" asp-route-id="@order.Id" 
                                       class="btn btn-outline-primary btn-sm w-100">
                                        <i class="fas fa-download me-1"></i>Download Receipt
                                    </a>
                                </div>
                            </div>

                            <!-- Payment & Points Info -->
                            <div class="row mt-3 pt-3 border-top">
                                <div class="col-md-4">
                                    <small class="text-muted">Payment:</small>
                                    <span class="ms-2 fw-bold">@order.PaymentMethod</span>
                                </div>
                                @if (order.PointsEarned > 0)
                                {
                                    <div class="col-md-4">
                                        <small class="text-muted">Points Earned:</small>
                                        <span class="ms-2 fw-bold text-success">+@order.PointsEarned pts</span>
                                    </div>
                                }
                                @if (order.PointsRedeemed > 0)
                                {
                                    <div class="col-md-4">
                                        <small class="text-muted">Points Redeemed:</small>
                                        <span class="ms-2 fw-bold text-primary">-@order.PointsRedeemed pts</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Summary Stats -->
        <div class="row mt-5">
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <i class="fas fa-shopping-cart fa-3x mb-3" style="color: var(--primary-color);"></i>
                        <h3 class="fw-bold mb-1">@Model.Count</h3>
                        <p class="text-muted mb-0">Total Orders</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <i class="fas fa-dollar-sign fa-3x mb-3" style="color: var(--success-color);"></i>
                        <h3 class="fw-bold mb-1">$@Model.Sum(o => o.TotalAmount).ToString("F2")</h3>
                        <p class="text-muted mb-0">Total Spent</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <i class="fas fa-star fa-3x mb-3" style="color: #ffd700;"></i>
                        <h3 class="fw-bold mb-1">@Model.Sum(o => o.PointsEarned)</h3>
                        <p class="text-muted mb-0">Points Earned</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- No Orders -->
        <div class="text-center py-5">
            <i class="fas fa-receipt fa-5x text-muted mb-4"></i>
            <h3 class="text-muted mb-3">No orders yet</h3>
            <p class="text-muted mb-4">Start ordering delicious food today!</p>
            <a asp-controller="Home" asp-action="Menu" class="btn btn-primary btn-lg">
                <i class="fas fa-utensils me-2"></i>Browse Menu
            </a>
        </div>
    }
</div>
