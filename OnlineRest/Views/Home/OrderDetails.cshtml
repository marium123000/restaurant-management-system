@model OnlineRest.Models.Order
@{
    ViewData["Title"] = "Order Details";
    var statusClass = Model.Status switch
    {
        "Delivered" => "status-delivered",
        "Out for Delivery" => "status-out-for-delivery",
        "Processing" => "status-processing",
        "Cancelled" => "status-cancelled",
        _ => "status-pending"
    };
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fas fa-receipt me-2"></i>Order #@Model.Id
        </h2>
        <a asp-action="OrderHistory" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Orders
        </a>
    </div>

    <div class="row">
        <!-- Order Information -->
        <div class="col-lg-8 mb-4">
            <!-- Status Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <h5 class="fw-bold mb-2">Order Status</h5>
                            <span class="status-badge @statusClass">@Model.Status</span>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <p class="text-muted small mb-1">Order Date</p>
                            <p class="fw-bold mb-0">@Model.OrderDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-shopping-bag me-2"></i>Order Items
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="p-3">Item</th>
                                    <th class="p-3 text-center">Quantity</th>
                                    <th class="p-3 text-end">Unit Price</th>
                                    <th class="p-3 text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null)
                                {
                                    foreach (var item in Model.OrderDetails)
                                    {
                                        <tr>
                                            <td class="p-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@(item.FoodItem?.ImageUrl ?? "/images/placeholder.jpg")" 
                                                         alt="@item.FoodItem?.Name" 
                                                         class="rounded me-3"
                                                         style="width: 60px; height: 60px; object-fit: cover;" />
                                                    <div>
                                                        <h6 class="mb-1 fw-bold">@item.FoodItem?.Name</h6>
                                                        <small class="text-muted">@item.FoodItem?.Category</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="p-3 text-center fw-bold">x @item.Quantity</td>
                                            <td class="p-3 text-end">$@item.UnitPrice.ToString("F2")</td>
                                            <td class="p-3 text-end fw-bold">$@((item.Quantity * item.UnitPrice).ToString("F2"))</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Delivery Information -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-map-marker-alt me-2"></i>Delivery Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <p class="text-muted mb-1">Delivery Address</p>
                        <p class="fw-bold mb-0">@Model.ShippingAddress</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                    {
                        <div>
                            <p class="text-muted mb-1">Special Instructions</p>
                            <p class="fst-italic mb-0">@Model.SpecialInstructions</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="col-lg-4">
            <!-- Payment Summary -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-file-invoice-dollar me-2"></i>Payment Summary
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <span class="fw-bold">$@Model.TotalAmount.ToString("F2")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Delivery Fee:</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>

                    @if (Model.PointsRedeemed > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Points Discount:</span>
                            <span class="fw-bold">-$@((Model.PointsRedeemed * 0.01m).ToString("F2"))</span>
                        </div>
                    }

                    <hr />

                    <div class="d-flex justify-content-between mb-3">
                        <span class="h5 fw-bold">Total:</span>
                        <span class="h5 fw-bold" style="color: var(--primary-color);">
                            $@((Model.TotalAmount - (Model.PointsRedeemed * 0.01m)).ToString("F2"))
                        </span>
                    </div>

                    <div class="mb-3">
                        <p class="text-muted small mb-1">Payment Method</p>
                        <p class="fw-bold mb-0">
                            <i class="fas fa-wallet me-2"></i>@Model.PaymentMethod
                        </p>
                    </div>

                    <div>
                        <p class="text-muted small mb-1">Payment Status</p>
                        <span class="badge @(Model.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">
                            @Model.PaymentStatus
                        </span>
                    </div>
                </div>
            </div>

            <!-- Loyalty Points -->
            @if (Model.PointsEarned > 0 || Model.PointsRedeemed > 0)
            {
                <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-star fa-3x mb-3" style="color: var(--dark-color);"></i>
                        <h5 class="fw-bold mb-3" style="color: var(--dark-color);">Loyalty Points</h5>
                        
                        @if (Model.PointsEarned > 0)
                        {
                            <div class="mb-2">
                                <span style="color: var(--dark-color);">Points Earned:</span>
                                <strong class="ms-2" style="color: var(--success-color);">+@Model.PointsEarned</strong>
                            </div>
                        }
                        
                        @if (Model.PointsRedeemed > 0)
                        {
                            <div>
                                <span style="color: var(--dark-color);">Points Redeemed:</span>
                                <strong class="ms-2" style="color: var(--primary-color);">-@Model.PointsRedeemed</strong>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Actions -->
            <div class="d-grid gap-2">
                <a asp-action="DownloadReceipt" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-download me-2"></i>Download Receipt
                </a>
                <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-primary">
                    <i class="fas fa-redo me-2"></i>Order Again
                </a>
            </div>

            <!-- Customer Support -->
            <div class="card border-0 shadow-sm mt-4" style="background: var(--light-color);">
                <div class="card-body p-3 text-center">
                    <h6 class="fw-bold mb-2">Need Help?</h6>
                    <p class="small text-muted mb-2">Contact our support team</p>
                    <p class="mb-0">
                        <i class="fas fa-phone me-2"></i>
                        <strong>+92-300-1234567</strong>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
