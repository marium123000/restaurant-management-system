<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <!-- CRITICAL: Fixed viewport for automation testing - prevents zoom issues -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - Delicious Bites Restaurant</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-utensils"></i> Delicious Bites
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Menu">
                            <i class="fas fa-book-open"></i> Menu
                        </a>
                    </li>
                    @if (Context.Session.GetInt32("UserId") != null && Context.Session.GetString("IsAdmin") != "True")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Reservations">
                                <i class="fas fa-calendar-check"></i> Reservations
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        @if (Context.Session.GetString("IsAdmin") != "True")
                        {
                            var loyaltyPoints = Context.Session.GetInt32("LoyaltyPoints") ?? 0;
                            <li class="nav-item">
                                <span class="nav-link loyalty-badge">
                                    <i class="fas fa-star"></i> @loyaltyPoints pts
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                    <i class="fas fa-shopping-cart"></i> Cart
                                    @{
                                        var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
                                        if (cartCount > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                                @cartCount
                                            </span>
                                        }
                                    }
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="OrderHistory">
                                    <i class="fas fa-history"></i> Orders
                                </a>
                            </li>
                        }
                        
                        @if (Context.Session.GetString("IsAdmin") == "True")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="fas fa-tachometer-alt"></i> Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i> @Context.Session.GetString("UserName")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (Context.Session.GetString("IsAdmin") != "True")
                                {
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user"></i> Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary text-white ms-2" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus"></i> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-utensils"></i> Delicious Bites</h5>
                    <p>Experience the finest dining with our carefully crafted menu and exceptional service.</p>
                    <div class="social-links">
                        <a href="#" class="me-3"><i class="fab fa-facebook fa-2x"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram fa-2x"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-twitter fa-2x"></i></a>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-clock"></i> Opening Hours</h5>
                    <p>Monday - Friday: 11:00 AM - 11:00 PM</p>
                    <p>Saturday - Sunday: 10:00 AM - 12:00 AM</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-map-marker-alt"></i> Contact Us</h5>
                    <p><i class="fas fa-phone"></i> +92-300-1234567</p>
                    <p><i class="fas fa-envelope"></i> info@deliciousbites.com</p>
                    <p><i class="fas fa-location-dot"></i> Karachi, Pakistan</p>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.2);" />
            <div class="text-center">
                <p>&copy; @DateTime.Now.Year Delicious Bites Restaurant. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- Custom Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>