@model OnlineRest.Models.Order
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <!-- Success Header -->
            <div class="text-center mb-3">
                <i class="fas fa-check-circle text-success" style="font-size: 3rem;"></i>
                <h4 class="fw-bold mt-2 mb-1">Order Confirmed!</h4>
                <p class="text-muted mb-0">Order #@Model.Id</p>
            </div>

            <!-- Order Summary Card -->
            <div class="card shadow-sm mb-2">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3">Order Summary</h6>
                    
                    <!-- Order Items -->
                    @if (Model.OrderDetails != null)
                    {
                        foreach (var item in Model.OrderDetails)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@item.FoodItem?.Name <small class="text-muted">x@item.Quantity</small></span>
                                <span>$@((item.Quantity * item.UnitPrice).ToString("F2"))</span>
                            </div>
                        }
                    }

                    <hr class="my-2" />

                    <!-- Pricing -->
                    <div class="d-flex justify-content-between mb-1">
                        <span>Subtotal</span>
                        <span>$@((Model.TotalAmount + (Model.PointsRedeemed * 0.01m)).ToString("F2"))</span>
                    </div>

                    @if (Model.PointsRedeemed > 0)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success">
                            <span>Points Discount</span>
                            <span>-$@((Model.PointsRedeemed * 0.01m).ToString("F2"))</span>
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span class="text-primary">$@Model.TotalAmount.ToString("F2")</span>
                    </div>

                    @if (Model.PointsEarned > 0)
                    {
                        <div class="alert alert-success p-2 mt-2 mb-0">
                            <small><i class="fas fa-star me-1"></i>You earned <strong>@Model.PointsEarned points</strong></small>
                        </div>
                    }
                </div>
            </div>

            <!-- Delivery Info -->
            <div class="card shadow-sm mb-2">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3">Delivery Information</h6>
                    
                    <div class="row g-2">
                        <div class="col-6">
                            <small class="text-muted d-block">Order Date</small>
                            <span class="small">@Model.OrderDate.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Status</small>
                            <span class="badge bg-warning small">@Model.Status</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Payment</small>
                            <span class="small">@Model.PaymentMethod</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Payment Status</small>
                            <span class="badge bg-info small">@Model.PaymentStatus</span>
                        </div>
                        <div class="col-12">
                            <small class="text-muted d-block">Delivery Address</small>
                            <span class="small">@Model.ShippingAddress</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                        {
                            <div class="col-12">
                                <small class="text-muted d-block">Special Instructions</small>
                                <span class="small fst-italic">@Model.SpecialInstructions</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-grid gap-2 mb-2">
                <a asp-controller="Home" asp-action="DownloadReceipt" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-download me-2"></i>Download Receipt
                </a>
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-controller="Home" asp-action="OrderHistory" class="btn btn-outline-primary w-100">
                            <i class="fas fa-history me-1"></i>My Orders
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-primary w-100">
                            <i class="fas fa-utensils me-1"></i>Order Again
                        </a>
                    </div>
                </div>
            </div>

            <!-- Info -->
            <div class="text-center text-muted small">
                <p class="mb-1">Estimated delivery: 30-45 minutes</p>
                <p class="mb-0">Questions? Call us at +92-300-1234567</p>
            </div>
        </div>
    </div>
</div>
