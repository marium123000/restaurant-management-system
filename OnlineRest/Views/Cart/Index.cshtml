@model List<OnlineRest.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
    var subtotal = ViewBag.SubTotal as decimal? ?? 0;
}

<div class="container my-5">
    <h2 class="fw-bold mb-4">
        <i class="fas fa-shopping-cart me-2"></i>Shopping Cart
    </h2>

    @if (Model.Any())
    {
        <div class="row">
            <!-- Cart Items -->
            <div class="col-lg-8 mb-4">
                @foreach (var item in Model)
                {
                    <div class="cart-item fade-in">
                        <img src="@(item.ImageUrl ?? "/images/placeholder.jpg")" alt="@item.FoodItemName" />
                        
                        <div class="flex-grow-1">
                            <h5 class="fw-bold mb-2">@item.FoodItemName</h5>
                            <p class="text-muted mb-2">Price: $@item.Price.ToString("F2")</p>
                            
                            <!-- Quantity Controls -->
                            <form asp-action="UpdateCart" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="foodItemId" value="@item.FoodItemId" />
                                <div class="quantity-control">
                                    <button type="button" class="btn-decrease" onclick="decreaseQuantity(@item.FoodItemId)">
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <input type="number" 
                                           id="qty-@item.FoodItemId" 
                                           name="quantity" 
                                           value="@item.Quantity" 
                                           min="1" 
                                           max="10" 
                                           readonly />
                                    <button type="button" class="btn-increase" onclick="increaseQuantity(@item.FoodItemId)">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                    <button type="submit" class="btn btn-sm btn-primary ms-2">
                                        <i class="fas fa-sync-alt"></i> Update
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="text-end">
                            <p class="fw-bold mb-3" style="font-size: 1.25rem; color: var(--primary-color);">
                                $@((item.Price * item.Quantity).ToString("F2"))
                            </p>
                            <a asp-action="RemoveFromCart" asp-route-foodItemId="@item.FoodItemId" 
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Remove this item from cart?')">
                                <i class="fas fa-trash me-1"></i>Remove
                            </a>
                        </div>
                    </div>
                }

                <!-- Clear Cart Button -->
                <div class="text-end mt-3">
                    <a asp-action="ClearCart" class="btn btn-outline-danger" onclick="return confirm('Clear entire cart?')">
                        <i class="fas fa-trash-alt me-2"></i>Clear Cart
                    </a>
                </div>
            </div>

            <!-- Cart Summary -->
            <div class="col-lg-4">
                <div class="cart-summary">
                    <h4 class="fw-bold mb-4">Order Summary</h4>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span>Subtotal (@Model.Sum(i => i.Quantity) items):</span>
                        <span class="fw-bold">$@subtotal.ToString("F2")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Delivery Fee:</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5 fw-bold">Total:</span>
                        <span class="h5 fw-bold" style="color: var(--primary-color);">$@subtotal.ToString("F2")</span>
                    </div>

                    <a asp-action="Checkout" class="btn btn-success btn-lg w-100 mb-3">
                        <i class="fas fa-credit-card me-2"></i>Proceed to Checkout
                    </a>

                    <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-primary w-100">
                        <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                    </a>

                    <!-- Loyalty Points Info -->
                    <div class="alert alert-info mt-4">
                        <i class="fas fa-star me-2"></i>
                        <strong>Earn @((int)Math.Floor(subtotal)) loyalty points</strong> with this order!
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Empty Cart -->
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
            <h3 class="text-muted mb-3">Your cart is empty</h3>
            <p class="text-muted mb-4">Add some delicious items to get started!</p>
            <a asp-controller="Home" asp-action="Menu" class="btn btn-primary btn-lg">
                <i class="fas fa-utensils me-2"></i>Browse Menu
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function decreaseQuantity(itemId) {
            var input = document.getElementById('qty-' + itemId);
            var currentValue = parseInt(input.value);
            if (currentValue > 1) {
                input.value = currentValue - 1;
            }
        }

        function increaseQuantity(itemId) {
            var input = document.getElementById('qty-' + itemId);
            var currentValue = parseInt(input.value);
            if (currentValue < 10) {
                input.value = currentValue + 1;
            }
        }
    </script>
}
