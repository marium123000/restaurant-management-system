@model OnlineRest.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<div class="container my-5">
    <div class="row">
        <!-- Profile Info & Loyalty Points -->
        <div class="col-lg-4 mb-4">
            <!-- Profile Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center p-4">
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 100px; height: 100px;">
                        <i class="fas fa-user fa-3x"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@Model.Name</h4>
                    <p class="text-muted mb-3">@Model.Email</p>
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <p class="text-muted mb-0">
                            <i class="fas fa-phone me-2"></i>@Model.PhoneNumber
                        </p>
                    }
                </div>
            </div>

            <!-- Loyalty Points Card -->
            <div class="card border-0 shadow-lg mb-4" style="background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-star fa-3x mb-3" style="color: var(--dark-color);"></i>
                    <h5 class="fw-bold mb-2" style="color: var(--dark-color);">Loyalty Points</h5>
                    <h1 class="display-3 fw-bold mb-2" style="color: var(--dark-color);">@Model.LoyaltyPoints</h1>
                    <p class="mb-0" style="color: var(--dark-color);">
                        Worth $@((Model.LoyaltyPoints / 100m).ToString("F2"))
                    </p>
                    <small class="d-block mt-2" style="color: var(--dark-color);">
                        100 points = $1 discount
                    </small>
                </div>
            </div>

            <!-- Stats Card -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chart-line me-2"></i>Your Statistics
                    </h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Total Orders:</span>
                        <span class="fw-bold">@(Model.Orders?.Count ?? 0)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Total Spent:</span>
                        <span class="fw-bold">$@((Model.Orders?.Sum(o => o.TotalAmount) ?? 0).ToString("F2"))</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Member Since:</span>
                        <span class="fw-bold">@DateTime.Now.ToString("MMM yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Profile Form -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 p-4">
                    <h4 class="fw-bold mb-0">
                        <i class="fas fa-edit me-2"></i>Edit Profile
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <!-- Basic Information -->
                        <h5 class="fw-bold mb-3">Basic Information</h5>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-user me-2"></i>Full Name
                                </label>
                                <input type="text" name="name" value="@Model.Name" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-envelope me-2"></i>Email Address
                                </label>
                                <input type="email" name="email" value="@Model.Email" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fas fa-phone me-2"></i>Phone Number
                            </label>
                            <input type="tel" name="phoneNumber" value="@Model.PhoneNumber" class="form-control" placeholder="+92-300-1234567" />
                        </div>

                        <hr class="my-4" />

                        <!-- Change Password -->
                        <h5 class="fw-bold mb-3">Change Password (Optional)</h5>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-lock me-2"></i>Current Password
                                </label>
                                <input type="password" name="currentPassword" class="form-control" placeholder="Enter current password" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-key me-2"></i>New Password
                                </label>
                                <input type="password" name="newPassword" class="form-control" placeholder="Enter new password" />
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Leave password fields empty if you don't want to change your password.
                        </div>

                        <!-- Submit Button -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="row mt-4">
                <div class="col-md-6 mb-3">
                    <a asp-controller="Home" asp-action="OrderHistory" class="card border-0 shadow-sm text-decoration-none h-100">
                        <div class="card-body p-4 text-center">
                            <i class="fas fa-history fa-3x mb-3" style="color: var(--primary-color);"></i>
                            <h5 class="fw-bold mb-2">Order History</h5>
                            <p class="text-muted mb-0">View your past orders</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 mb-3">
                    <a asp-controller="Home" asp-action="Reservations" class="card border-0 shadow-sm text-decoration-none h-100">
                        <div class="card-body p-4 text-center">
                            <i class="fas fa-calendar-check fa-3x mb-3" style="color: var(--primary-color);"></i>
                            <h5 class="fw-bold mb-2">My Reservations</h5>
                            <p class="text-muted mb-0">Manage table bookings</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
